# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; this file (`.env.example`) is the checked-in template.

# ─── Required ────────────────────────────────────────────────────────

# PostgreSQL connection string used by Prisma and the repository layer.
# Create the database first (see README § Infrastructure Setup).
DATABASE_URL="postgresql://user:password@localhost:5432/ga_scheduler_v2?schema=public"

# HS256 symmetric key for signing JWT access tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""

# ─── Optional ────────────────────────────────────────────────────────

# Redis connection used by BullMQ (job queue) and the pub/sub progress channel.
# Defaults to redis://127.0.0.1:6379 if unset.
# REDIS_URL="redis://127.0.0.1:6379"

# API server listen port. Defaults to 3000 if unset.
# PORT=3000

# Only set when running the SQLite/libSQL thesis-defense fallback.
# Switches src/repo/competencyCodec.ts to JSON-encode competency arrays.
# Requires regenerating migrations against a SQLite target first.
# DATABASE_PROVIDER="sqlite"
