# Copy this file to `.env.demo` and fill in real values.
# `.env.demo` is gitignored; this file (`.env.demo.example`) is the checked-in template.
#
# Purpose: an isolated database for the working demo build, so schema changes
# made on feature/fix branches do NOT corrupt the version you present.
# Used by the `*:demo` npm scripts (db:migrate:demo, db:seed:demo, api:dev:demo,
# worker:demo, check:migrations:demo), which load this file via dotenv-cli.
#
# Create the demo database first (see README § Demo database isolation):
#   createdb ga_scheduler_v2_demo

# ─── Required ────────────────────────────────────────────────────────

DATABASE_URL="postgresql://user:password@localhost:5432/ga_scheduler_v2_demo?schema=public"

# Reuse the same JWT secret as .env unless you want demo tokens to be
# incompatible with dev tokens.
JWT_SECRET=""

# ─── Optional ────────────────────────────────────────────────────────

# REDIS_URL="redis://127.0.0.1:6379"
# PORT=3001
